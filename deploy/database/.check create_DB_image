#!/bin/bash

# ==========================================================================================
# ОПИСАНИЕ ПРОЦЕССА (ЧТО ПРОИСХОДИТ В DOCKERFILE):
# Для того чтобы этот скрипт сработал, ваш Dockerfile должен содержать команду:
# "COPY init-dump.sql /docker-entrypoint-initdb.d/"[cite: 3].
# 
# Как это работает:
# 1. Сборка (Build): Docker берет ваш текстовый файл 'init-dump.sql' и физически 
#    копирует его внутрь файловой системы образа.
# 2. Инициализация: Официальный образ PostgreSQL при самом первом запуске сканирует 
#    папку '/docker-entrypoint-initdb.d/'.
# 3. Автозапуск: Все .sql файлы, найденные в этой папке, исполняются автоматически 
#    в алфавитном порядке.
# ==========================================================================================

# ШАГ 1: Сборка образа (Build)
# Команда читает Dockerfile, скачивает Postgres и «зашивает» внутрь ваш дамп[cite: 3].
# Точка в конце указывает на текущую директорию[cite: 4].
docker build -t test-s5-db:latest .
# Убедитесь, что в конце вывода написано 'Successfully built' или 'DONE'[cite: 5].

# ШАГ 2: Запуск тестового контейнера (Run)
# Мы создаем переменные окружения, чтобы Postgres знал имя базы и пароль[cite: 7].
# Дамп будет развернут именно в базу S5_DB[cite: 7, 8].
docker run --name my-test-db \
  -e POSTGRES_USER=postgres \
  -e POSTGRES_PASSWORD=secret \
  -e POSTGRES_DB=S5_DB \
  -p 5432:5432 \
  -d test-s5-db:latest

# ШАГ 3: Проверка логов (Самый важный шаг)
# Мы смотрим, как идет процесс заливки дампа[cite: 8, 9].
# Вы должны увидеть строку 'running /docker-entrypoint-initdb.d/init-dump.sql'.
# Нажмите Ctrl+C, когда увидите: 'database system is ready to accept connections'[cite: 12, 13].
echo "Отслеживание логов... Ожидайте готовности системы (Ctrl+C для выхода)."
docker logs -f my-test-db

# ШАГ 4: Проверка данных внутри базы
# Заходим в базу и выводим список всех созданных таблиц (\dt)[cite: 14, 15].
# Если список таблиц появился — всё прошло идеально[cite: 15].
docker exec -it my-test-db psql -U postgres -d S5_DB -c "\dt"

# ШАГ 5: Уборка
# Удаляем контейнер, чтобы он не занимал ресурсы и порт 5432[cite: 16].
docker rm -f my-test-db
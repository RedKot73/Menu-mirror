{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "PrimaryConnection": {
    "DB_Host": "localhost",
    "DB_Name": "S5_DB",
    "Port": "5432",
    "CommandTimeout": 600,
    "Timeout": 1024,
    "SearchPath": "core,dict,docs,identity,history,public"
  },
  "AllowedOrigins": [
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/s5server-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "AllowedHosts": "*"
}
{
  "ConnectionStrings": {
    "DefaultConnection": "" // Буде з Azure App Settings
  },
  "PrimaryConnection": {
    "Host": "localhost",
    "Database": "S5_DB",
    "Port": "5432",
    "CommandTimeout": 600,
    "Timeout": 1024,
    "SearchPath": "core,dict,docs,identity,history,public" //порядок перегляду схеми при пошуку таблиці
  },
  "AllowedOrigins": [],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Information", //"Warning",
        "Microsoft.AspNetCore": "Information", //"Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/s5server-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information", //"Warning",
      "Microsoft.AspNetCore": "Information" //"Warning",
    }
  },
  "AllowedHosts": "*"
}

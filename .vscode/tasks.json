{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "start",
      "path": "S5Server/Front/",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "bundle generation complete"
          }
        }
      }
    },
    {
      "label": "ng serve (proxy)",
      "type": "shell",
      "command": "ng",
      "args": [
        "serve",
        "--proxy-config",
        "proxy.conf.json"
      ],
      "options": {
        "cwd": "${workspaceFolder}/S5Server/Front"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "bundle generation complete"
          }
        }
      }
    },
    {
      "label": "run server",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run"
      ],
      "options": {
        "cwd": "${workspaceFolder}/S5Server"
      },
      "isBackground": true,
      "problemMatcher": "$msCompile"
    },
    {
      "label": "start full-stack",
      "dependsOrder": "parallel",
      "dependsOn": [
        "ng serve (proxy)",
        "run server"
      ]
    }
  ]
}
